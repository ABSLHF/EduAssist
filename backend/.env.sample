DB_URL=mysql+mysqlconnector://root:root@127.0.0.1:3306/eduassist?charset=utf8mb4
CHROMA_PATH=./chroma
MATERIAL_STORAGE_MODE=local
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BUCKET=your_bucket
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_SECURE=true
GLM_API_KEY=your_glm_key
ERNIE_API_KEY=your_ernie_key
DIFY_API_KEY=your_dify_key
DIFY_BASE_URL=https://dify.aipfuture.com/v1
MODEL_PROVIDER=dify
DOC_CHUNK_SIZE=220
DOC_CHUNK_OVERLAP=40
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_FALLBACK_MODEL=all-MiniLM-L6-v2
ENABLE_SMALL_QA_ASSIST=false
ENABLE_FINETUNED_QA_IN_RAG=true
FINETUNED_QA_MODEL_PATH=
FINETUNED_QA_MIN_CONF=0.35
FINETUNED_QA_TOP_CHUNKS=4
FINETUNED_QA_MAX_EVIDENCE=2
ENABLE_ASSIGNMENT_RELEVANCE_MODEL=false
ASSIGNMENT_RELEVANCE_MODEL_PATH=
ASSIGNMENT_RELEVANCE_THRESHOLD_HI=0.70
ASSIGNMENT_RELEVANCE_THRESHOLD_LO=0.25
ASSIGNMENT_RELEVANCE_USE_RERANKER=false
ASSIGNMENT_RELEVANCE_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
ASSIGNMENT_RELEVANCE_RERANKER_WEIGHT=0.25
KG_EXTRACTOR=hybrid
KG_TOP_K=12
KG_MIN_TERM_LEN=2
KG_ENABLE_NOISE_FILTER=true
KG_STOPWORDS_PATH=training/data/kg_stopwords.txt
KG_DOMAIN_LEXICON_PATH=training/data/kg_domain_lexicon.txt
KG_UIE_MODEL_PATH=
KG_HANLP_MODEL=
KG_DEEPKE_ENDPOINT=
KG_DEEPKE_TIMEOUT_SECONDS=20
KG_DEEPKE_API_KEY=
KG_MIN_COOCCUR_COUNT=2
KG_EDGE_MIN_SCORE=1.0
KG_WEAK_EDGE_TOP_N=3
KG_WEAK_EDGE_MIN_SCORE=0.2
KG_MAX_TERM_DISTANCE=48
KG_CROSS_SENTENCE_PENALTY=0.2
CORS_ALLOW_ORIGINS=http://127.0.0.1:5999,http://localhost:5999,http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$
JWT_SECRET=change_me
JWT_ALGORITHM=HS256
